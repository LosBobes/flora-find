# FloraFind vhost for the shared Hetzner host.
#
# Caddy runs on the host and already serves gamgee (localhost:3000) and iris
# (localhost:3001). Do NOT overwrite the server's /etc/caddy/Caddyfile with
# this file: APPEND this block to it so the existing blocks are left untouched.
# See docs/deployment-hetzner.md.
#
# Caddy automatically obtains and renews a Let's Encrypt TLS certificate for
# this domain.

flora-find.com {
    reverse_proxy localhost:3002
}
