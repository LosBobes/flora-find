# Google Maps JavaScript API key (Maps JavaScript API must be enabled in Google Cloud Console)
VITE_GOOGLE_MAPS_API_KEY=your-key-here

# Optional: a Map ID is required for Advanced Markers. Create one in Google Cloud Console
# (Map Management) or leave the default DEMO_MAP_ID for development.
VITE_GOOGLE_MAPS_MAP_ID=DEMO_MAP_ID
