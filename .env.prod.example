# Production environment for the Hetzner deploy (docker-compose.prod.yml).
#
# Copy to `.env` on the server (next to docker-compose.prod.yml) and fill in
# real values. This file is gitignored on the server; never commit the real
# secrets.

# ── Postgres ─────────────────────────────────────────────────────────────────
# The db container is created with these credentials on first start, and the
# app builds FLORA_DATABASE_URL from them. POSTGRES_PASSWORD is REQUIRED.
# Generate a strong value with: openssl rand -hex 32
POSTGRES_USER=flora
POSTGRES_PASSWORD=
POSTGRES_DB=flora

# ── App secrets ──────────────────────────────────────────────────────────────
# JWT signing secret. REQUIRED: the backend refuses to start without it.
# Generate a long random value:
#   openssl rand -hex 32
FLORA_JWT_SECRET=

# Same-origin deploy (browser -> Caddy -> FastAPI), so this is just the public
# domain. Only add more origins if you serve the frontend elsewhere.
FLORA_CORS_ORIGINS=https://flora-find.com
